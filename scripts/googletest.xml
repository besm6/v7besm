<?xml version="1.0"?>
<!--
  Minimal cppcheck library definition for GoogleTest.

  Teaches cppcheck about the GoogleTest macros so it does not emit false
  positives (e.g. unreachable code / syntax confusion) when checking test
  sources.  Referenced from the top-level CMakeLists.txt via
  CMAKE_CXX_CPPCHECK --library=.../scripts/googletest.xml.
-->
<def format="2">
  <!-- TEST(suite, name) / TEST_F(fixture, name) define a function body. -->
  <define name="TEST(a,b)"      value="void a##_##b()"/>
  <define name="TEST_F(a,b)"    value="void a##_##b()"/>
  <define name="TEST_P(a,b)"    value="void a##_##b()"/>
  <define name="TYPED_TEST(a,b)" value="void a##_##b()"/>

  <!-- Assertion macros evaluate their arguments; mark them (arg nr) so cppcheck
       does not treat the argument values as unused.  The macros themselves may
       be used without consuming their return value (a bare EXPECT_TRUE(...) with
       no trailing "<< msg" is idiomatic gtest), so they are NOT use-retval. -->
  <function name="EXPECT_EQ"><arg nr="any"/></function>
  <function name="EXPECT_NE"><arg nr="any"/></function>
  <function name="EXPECT_TRUE"><arg nr="1"/></function>
  <function name="EXPECT_FALSE"><arg nr="1"/></function>
  <function name="ASSERT_EQ"><arg nr="any"/></function>
  <function name="ASSERT_NE"><arg nr="any"/></function>
  <function name="ASSERT_TRUE"><arg nr="1"/></function>
  <function name="ASSERT_FALSE"><arg nr="1"/></function>
</def>
