#!/bin/sh
#
# mkstub NAME TABLE -- write the uniform syscall stub for NAME on stdout.
#
# Called once per entry of sys/syscalls.tbl by lib/libc/Makefile, which keeps one
# generated .s and one object per syscall so that b6ranlib's index lets b6ld pull
# only what a program actually calls.
#
# There is no prologue and no stack adjustment, and that is the point: the C calling
# convention has already put arguments 1..n-1 below r15 and the last one in the
# accumulator, which is exactly where the gate reads them, and the gate performs the
# callee's cleanup (`tr->r15 -= n - 1') on the stub's behalf.  A b$save here would
# move the arguments out from under it.  See lib/README.md, "Ground rules".

name=$1
tbl=$2

if [ -z "$name" ] || [ -z "$tbl" ]; then
    echo "usage: mkstub name table" >&2
    exit 1
fi

# Strip comments and blank lines, then take the number beside the name.  A missing
# entry is a Makefile bug, not a user error, so it fails loudly.
num=`sed -e 's/#.*//' "$tbl" | awk -v n="$name" '$1 == n { print $2; exit }'`
if [ -z "$num" ]; then
    echo "mkstub: $name: no such entry in $tbl" >&2
    exit 1
fi

# The prototype comment from the table travels into the generated file: it is the
# arity the gate assumes, and the one thing a reader of the stub cannot see.
proto=`grep "^$name[ 	]" "$tbl" | sed -e 's/^[^#]*#[ ]*//' -e q`

cat <<EOF
// GENERATED by sys/mkstub from sys/syscalls.tbl -- do not edit.
//
//      $proto
//
// The bare gate: issue the extracode, and let cerror store errno and return -1 if
// r14 came back non-zero.  No prologue, and nothing popped -- the gate stands in for
// the called function and does the callee's cleanup itself.
//
        .text
        .globl  $name, cerror
$name:
        \$77 $num
     14 v1m     cerror
     13 uj
EOF
