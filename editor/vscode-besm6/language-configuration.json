                "string",
                "comment"
            ]
        }
    ],
    "surroundingPairs": [
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ],
        [
            "{",
            "}"
        ],
        [
            "<",
            ">"
        ],
        [
            "\"",
