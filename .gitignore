# The uniform syscall stubs lib/libc/Makefile generates from sys/syscalls.tbl, one
# per line.  They land beside the objects, so this does NOT match the hand-written
# leaves next door in lib/libc/sys/.  Both cases: the generator emits .S (the stub
# includes <sys/syscall.h>), and b6cc leaves a .s behind if ever run with -S.
lib/libc/*.S
lib/libc/*.s

# Linked BESM-6 images built by lib/test/Makefile, and the output each run is
# diffed against its .expected file.
lib/test/hello
lib/test/vararg
lib/test/errno
lib/test/procs
lib/test/sbrkt
lib/test/strings
lib/test/gen
lib/test/environ
lib/test/jmp
lib/test/*.out

# Scratch drum and disk images that kernel/test/mbtest.ini and mdtest.ini create with
# `attach -n'.  The disk images are ~8 Mb each and there are three of them.
*.drum
*.disk
